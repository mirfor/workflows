          "operation": "http_get",
          "errors": [
            {
              "type": "IntegrationError",
              "is_base": true,
              "retryable": true
            }
          ],
          "defaultRetryProfile": "default_retry",
          "defaultTimeoutProfile": "default_timeout",
          "idempotent": true
        },
        "log_message": {
          "name": "log_message",
          "type": "weaver_tool",
          "module": "activities.tools.log_message",
          "operation": "log_message",
          "errors": [
            {
              "type": "ValidationError",
              "is_base": true,
              "retryable": false
            }
          ],
          "defaultRetryProfile": null,
          "defaultTimeoutProfile": "default_timeout",
          "idempotent": true
        }
      },
      "retries": {
        "default_retry": {
          "delay": "PT1S",
          "backoff": {
            "exponential": {
              "multiplier": 2
            }
          },
          "limit": {
            "attempt": {
              "count": 3
            }
          },
          "nonRetryableTypes": [
            "ValidationError"
          ]
        }
      },
      "timeouts": {
        "default_timeout": {
          "after": "PT30S"
        }
      }
    },
    "metadata": null,
    "workflowRunTimeout": null
  },
  "nodes": [
    {
