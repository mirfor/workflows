{
  "document": {
    "dsl": "1.0.0",
    "namespace": "demo",
    "name": "iteration",
    "version": "1",
    "summary": "For-loop test: iterate over input.items, log each, count."
  },
  "use": {
    "authentications": {},
    "errors": {},
    "extensions": {},
    "functions": {
      "log_message": {
        "name": "log_message",
        "type": "weaver_tool",
        "operation": "log_message",
        "errors": [],
        "defaultTimeoutProfile": "default_timeout",
        "idempotent": true,
        "module": "activities.tools.log_message"
      }
    },
    "retries": {},
    "secrets": [],
    "timeouts": {
      "default_timeout": {
        "after": "PT2M",
        "metadata": {
          "temporal": {
            "heartbeat": "PT30S"
          }
        }
      }
    }
  },
  "do": [
    {
      "loop": {
        "for": {
          "each": "item",
          "in": ".input.items"
        },
        "do": [
          {
            "log_each": {
              "set": {
                "ref": "$item"
              }
            }
          }
        ]
      }
    }
  ],
  "metadata": {
    "weaver": {
      "trigger": {
        "type": "manual_trigger"
      }
    }
  }
}
