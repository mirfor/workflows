      "data": {
        "function": "log_message",
        "with": {
          "message": "Audit log entry written",
          "level": "INFO"
        },
        "timeout": "default_timeout"
      },
      "parentNode": null
    },
    {
      "id": "notify_metric",
      "type": "set",
      "data": {
        "assignments": {
          "metric_sent": true
        }
      },
      "parentNode": null
    },
    {
      "id": "finalize",
      "type": "set",
      "data": {
        "assignments": {
          "status": "completed",
          "finalized_at": "now"
        }
      },
      "parentNode": null
    },
    {
      "id": "log_done",
      "type": "call",
      "data": {
        "function": "log_message",
        "with": {
          "message": "Order processing complete",
          "level": "INFO"
        },
        "timeout": "default_timeout"
      },
      "parentNode": null
    }
  ],
