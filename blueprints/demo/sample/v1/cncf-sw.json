{
  "document": {
    "dsl": "1.0.0",
    "namespace": "demo",
    "name": "sample",
    "version": "1",
    "summary": "Sample Blueprint: log → switch (tier) → emit/raise."
  },
  "use": {
    "authentications": {},
    "errors": {},
    "extensions": {},
    "functions": {
      "log_message": {
        "name": "log_message",
        "type": "weaver_tool",
        "operation": "log_message",
        "errors": [
          {
            "type": "ValidationError",
            "retryable": false,
            "is_base": true
          }
        ],
        "defaultTimeoutProfile": "default_timeout",
        "idempotent": true,
        "module": "activities.tools.log_message"
      }
    },
    "retries": {
      "default_retry": {
        "delay": "PT1S",
        "backoff": {
          "exponential": {
            "multiplier": 2.0
          }
        },
        "limit": {
          "attempt": {
            "count": 3
          }
        },
        "nonRetryableTypes": [
          "ValidationError"
        ]
      }
    },
    "secrets": [],
    "timeouts": {
      "default_timeout": {
        "after": "PT2M",
        "metadata": {
          "temporal": {
            "heartbeat": "PT30S"
          }
        }
      }
    }
  },
  "do": [
    {
      "log_intro": {
        "timeout": "default_timeout",
        "call": "log_message",
        "with": {
          "message": "Sample workflow started",
          "level": "INFO"
        }
      }
    },
    {
      "decision": {
        "switch": [
          {
            "vip": {
              "when": ".input.tier == \"vip\"",
              "then": "log_vip",
              "do": [
                {
                  "log_vip": {
                    "set": {
                      "path": "vip",
                      "next": "emit_vip"
                    }
                  }
                },
                {
                  "emit_vip": {
                    "emit": {
                      "event": {
                        "with": {
                          "tier": "vip",
                          "msg": "VIP path taken"
                        }
                      }
                    }
                  }
                }
              ]
            }
          },
          {
            "default": {
              "then": "log_default",
              "do": [
                {
                  "log_default": {
                    "set": {
                      "path": "regular",
                      "next": "emit_regular"
                    }
                  }
                },
                {
                  "emit_regular": {
                    "emit": {
                      "event": {
                        "with": {
                          "tier": "regular",
                          "msg": "Regular path taken"
                        }
                      }
                    }
                  }
                }
              ]
            }
          }
        ]
      }
    }
  ],
  "metadata": {
    "weaver": {
      "trigger": {
        "type": "manual_trigger"
      }
    }
  }
}
