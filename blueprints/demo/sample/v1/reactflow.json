{
  "meta": {
    "namespace": "demo",
    "name": "sample",
    "version": "1",
    "summary": "Sample Blueprint: log → switch (tier) → emit/raise.",
    "use": {
      "functions": {
        "log_message": {
          "name": "log_message",
          "type": "weaver_tool",
          "module": "activities.tools.log_message",
          "operation": "log_message",
          "errors": [
            { "type": "ValidationError", "is_base": true, "retryable": false }
          ],
          "defaultRetryProfile": null,
          "defaultTimeoutProfile": "default_timeout",
          "idempotent": true
        }
      },
      "retries": {
        "default_retry": {
          "delay": "PT1S",
          "backoff": { "exponential": { "multiplier": 2.0 } },
          "limit": { "attempt": { "count": 3 } },
          "nonRetryableTypes": ["ValidationError"]
        }
      },
      "timeouts": {
        "default_timeout": {
          "after": "PT2M",
          "metadata": { "temporal": { "heartbeat": "PT30S" } }
        }
      }
    }
  },
  "nodes": [
    { "id": "trigger", "type": "manual_trigger", "data": {} },
    {
      "id": "log_intro",
      "type": "call",
      "data": {
        "function": "log_message",
        "with": { "message": "Sample workflow started", "level": "INFO" },
        "timeout": "default_timeout"
      }
    },
    {
      "id": "decision",
      "type": "switch",
      "data": {
        "cases": [
          { "id": "vip", "when": ".input.tier == \"vip\"" }
        ]
      }
    },
    {
      "id": "log_vip",
      "type": "set",
      "data": { "assignments": { "path": "vip", "next": "emit_vip" } }
    },
    {
      "id": "log_default",
      "type": "set",
      "data": { "assignments": { "path": "regular", "next": "emit_regular" } }
    },
    {
      "id": "emit_vip",
      "type": "emit",
      "data": { "event": { "tier": "vip", "msg": "VIP path taken" } }
    },
    {
      "id": "emit_regular",
      "type": "emit",
      "data": { "event": { "tier": "regular", "msg": "Regular path taken" } }
    }
  ],
  "edges": [
    { "id": "e1", "source": "trigger", "target": "log_intro" },
    { "id": "e2", "source": "log_intro", "target": "decision" },
    { "id": "e3", "source": "decision", "target": "log_vip", "sourceHandle": "case_vip" },
    { "id": "e4", "source": "decision", "target": "log_default", "sourceHandle": "default" },
    { "id": "e5", "source": "log_vip", "target": "emit_vip" },
    { "id": "e6", "source": "log_default", "target": "emit_regular" }
  ]
}
